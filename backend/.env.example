# ==========================================
# AGENDA FLOW - VARIÁVEIS DE AMBIENTE
# ==========================================

# Banco de Dados (MySQL)
DATABASE_URL="mysql://user:password@host:3306/agendaflow"

# Autenticação JWT
JWT_SECRET="sua_chave_secreta_aqui_mude_em_producao"

# OpenAI (opcional - sem API key usa heurística)
OPENAI_API_KEY=""

# Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_TOKEN="agendaflow_token"

# Redis (para filas BullMQ)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Node Environment
NODE_ENV=production

# Porta do servidor
PORT=3001

# Frontend URL (para CORS)
ALLOWED_ORIGINS="https://seudominio.com,http://localhost:3000"

# ==========================================
# MERCADO PAGO (SUBSTITUA COM SEUS DADOS)
# ==========================================
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
APP_URL=""